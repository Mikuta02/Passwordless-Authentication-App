<!DOCTYPE html>
<html lang="sr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pregled baze</title>
    <style>
      :root {
        --bg: #060b14;
        --panel: #0f1726;
        --ink: #f3f7ff;
        --muted: #9fb2d1;
        --accent: #3b82f6;
        --border: #213251;
      }

      body {
        margin: 0;
        font-family: "Segoe UI", -apple-system, BlinkMacSystemFont, "Inter", Roboto, sans-serif;
        background: radial-gradient(circle at top left, #0f1d36 0%, var(--bg) 45%, #030712 100%);
        color: var(--ink);
      }

      main {
        max-width: 1240px;
        margin: 0 auto;
        padding: 24px 18px 60px;
        position: relative;
      }

      main::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(59, 130, 246, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(59, 130, 246, 0.04) 1px, transparent 1px);
        background-size: 34px 34px;
        mask-image: radial-gradient(circle at 18% 20%, black, transparent 72%);
      }

      h1,
      h2 {
        margin: 0 0 12px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
      }

      .section {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 18px;
        box-shadow: 0 18px 38px rgba(2, 8, 23, 0.42);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
      }

      .section:hover {
        transform: translateY(-2px);
        box-shadow: 0 24px 48px rgba(2, 8, 23, 0.55);
        border-color: #30507f;
      }

      .table-wrap {
        overflow-x: auto;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        min-width: 760px;
      }

      th,
      td {
        text-align: left;
        padding: 10px 12px;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
      }

      th {
        background: #14223d;
        color: #dbeafe;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-size: 0.78rem;
      }

      tr:nth-child(even) td {
        background: rgba(20, 34, 61, 0.36);
      }

      code {
        white-space: pre-wrap;
        word-break: break-word;
        color: #dbeafe;
        font-family: "Consolas", "JetBrains Mono", monospace;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
      }

      a:hover {
        text-decoration: underline;
      }

      .muted {
        color: var(--muted);
      }
    </style>
  </head>
  <body>
    <main>
      <div class="topbar">
        <div>
          <h1>Pregled SQLite baze</h1>
          <div class="muted">Read-only pregled za razvoj i demonstraciju</div>
        </div>
        <a href="/">Nazad na aplikaciju</a>
      </div>

      <%- include('partials/table', { title: 'users', rows: users }) %>
      <%- include('partials/table', { title: 'magic_links', rows: magicLinks }) %>
      <%- include('partials/table', { title: 'login_attempts', rows: loginAttempts }) %>
      <%- include('partials/table', { title: 'audit_logs', rows: auditLogs }) %>
      <%- include('partials/table', { title: 'recovery_tokens', rows: recoveryTokens }) %>
      <%- include('partials/table', { title: 'recovery_codes', rows: recoveryCodes }) %>
      <%- include('partials/table', { title: 'trusted_devices', rows: trustedDevices }) %>
    </main>
  </body>
  </html>