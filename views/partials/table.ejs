<section class="section">
  <h2><%= title %></h2>
  <% if (!rows.length) { %>
    <div class="muted">Nema podataka.</div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <% Object.keys(rows[0]).forEach((key) => { %>
              <th><%= key %></th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach((row) => { %>
            <tr>
              <% Object.values(row).forEach((value) => { %>
                <td><code><%= value === null ? 'null' : String(value) %></code></td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>